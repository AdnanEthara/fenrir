<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="fenrir.AttachmentUploader">
    <div class="fenrir-attachment-uploader">

      <div class="d-flex align-items-center mb-2 gap-2 flex-wrap">
        <label class="text-muted small mb-0 me-1">Upload to folder:</label>
        <select class="form-select form-select-sm" style="width:auto"
                t-att-value="state.folder"
                t-on-change="onFolderChange"
                t-att-disabled="state.uploading">
          <option t-foreach="folders" t-as="f" t-key="f.value"
                  t-att-value="f.value"
                  t-att-selected="state.folder === f.value"
                  t-esc="f.label"/>
        </select>
        <span class="badge text-bg-light fw-normal ms-1">
          <i class="fa fa-cloud me-1" aria-hidden="true"/>S3
        </span>
        <div class="ms-auto d-flex gap-2">
          <button t-if="pendingCount" type="button" class="btn btn-sm btn-success"
                  t-on-click="onSaveAndUpload"
                  t-att-disabled="state.uploading">
            <i class="fa fa-cloud-upload me-1" aria-hidden="true"/>
            Save &amp; upload (<t t-esc="pendingCount"/>)
          </button>
          <button type="button" class="btn btn-sm btn-primary"
                  t-on-click="onPickClick"
                  t-att-disabled="state.uploading">
            <i class="fa fa-plus me-1" aria-hidden="true"/>
            Add files
          </button>
          <input type="file" t-ref="fileInput" multiple="multiple"
                 style="display:none" t-on-change="onFileChange"/>
        </div>
      </div>

      <div class="fenrir-dropzone"
           t-att-class="{ 'is-dragover': state.dragOver, 'is-uploading': state.uploading }"
           t-on-dragover="onDragOver"
           t-on-dragleave="onDragLeave"
           t-on-drop="onDrop"
           t-on-click="onPickClick"
           role="button">
        <div t-if="!state.uploading">
          <i class="fa fa-cloud-upload me-2" aria-hidden="true"/>
          <span>
            <strong>Drop files here</strong> or click to choose.
            The task auto-saves before each upload — fill any required fields first.
          </span>
        </div>
        <div t-if="state.uploading" class="w-100">
          <div class="d-flex align-items-center small">
            <i class="fa fa-spinner fa-spin me-2" aria-hidden="true"/>
            <span class="text-truncate flex-grow-1">
              <t t-if="state.totalCount &gt; 1">
                (<t t-esc="state.currentIndex"/>/<t t-esc="state.totalCount"/>)
              </t>
              Uploading <strong t-esc="state.currentName"/>…
            </span>
            <span class="ms-2 text-muted"><t t-esc="state.progress"/>%</span>
          </div>
          <div class="progress mt-1" style="height:4px">
            <div class="progress-bar bg-primary" role="progressbar"
                 t-att-style="`width:${state.progress}%`"/>
          </div>
        </div>
      </div>

      <div t-if="pendingCount" class="fenrir-pending-queue mt-2">
        <div class="small text-muted mb-1">
          <i class="fa fa-clock-o me-1" aria-hidden="true"/>
          Queued for next save:
        </div>
        <div class="d-flex flex-wrap gap-1">
          <span t-foreach="state.pendingFiles" t-as="pf" t-key="pf.id"
                class="badge text-bg-warning fw-normal d-inline-flex align-items-center">
            <i class="fa fa-file-o me-1" aria-hidden="true"/>
            <span t-esc="pf.name"/>
            <span class="text-muted ms-1" t-esc="'(' + pf.folder + ')'"/>
            <button type="button" class="btn btn-sm btn-link p-0 ms-2 text-dark"
                    t-att-title="'Remove ' + pf.name"
                    t-on-click="() => this.removePending(pf.id)">
              <i class="fa fa-times" aria-hidden="true"/>
            </button>
          </span>
        </div>
      </div>
    </div>
  </t>

</templates>
