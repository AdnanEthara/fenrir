<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fenrir_rubric_import_wizard_view_form" model="ir.ui.view">
        <field name="name">fenrir.rubric.import.wizard.form</field>
        <field name="model">fenrir.rubric.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Rubrics from CSV">
                <sheet>
                    <div class="oe_title">
                        <h1>Import Rubrics from CSV</h1>
                        <p class="text-muted">
                            Upload a 2-column CSV (name, description) to
                            populate this task's rubrics in bulk.
                        </p>
                    </div>

                    <group>
                        <field name="task_id" options="{'no_open': True}"/>
                        <field name="csv_file" filename="csv_filename"
                               widget="binary"/>
                        <field name="csv_filename" invisible="1"/>
                        <field name="has_header"/>
                        <field name="replace_existing"/>
                    </group>

                    <div class="alert alert-info mt-3" role="alert">
                        <strong>CSV format</strong>
                        <ul class="mb-2">
                            <li>Column 1: <code>name</code> (required)</li>
                            <li>Column 2: <code>description</code> (optional)</li>
                            <li>Comma, semicolon, or tab separators all work</li>
                            <li>UTF-8 or Latin-1 encoding</li>
                        </ul>
                        <p class="mb-1"><strong>Example:</strong></p>
                        <pre class="mb-2">name,description
Build runs,index.html loads without console errors
Mobile responsive,Canvas scales below 768px
Sound enabled,All sound effects play</pre>
                        <a href="/fenrir/static/src/sample_rubrics.csv"
                           download="sample_rubrics.csv"
                           class="btn btn-sm btn-secondary">
                            <i class="fa fa-download me-1"
                               title="Download" aria-label="Download"
                               role="img"/>
                            Download sample CSV
                        </a>
                    </div>
                </sheet>
                <footer>
                    <button string="Import" type="object" name="action_import"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="fenrir_rubric_import_wizard_action" model="ir.actions.act_window">
        <field name="name">Import Rubrics from CSV</field>
        <field name="res_model">fenrir.rubric.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="fenrir_rubric_import_wizard_view_form"/>
        <field name="target">new</field>
    </record>

</odoo>
