<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fenrir_rubric_score_import_wizard_view_form" model="ir.ui.view">
        <field name="name">fenrir.rubric.score.import.wizard.form</field>
        <field name="model">fenrir.rubric.score.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Rubric Scores from CSV">
                <sheet>
                    <div class="oe_title">
                        <h1>Import Rubric Scores</h1>
                        <p class="text-muted">
                            Upload a CSV (typically the one exported earlier
                            and edited in Excel) to bulk-update this seller's
                            rubric ratings + justifications.
                        </p>
                    </div>

                    <group>
                        <field name="seller_offer_id"
                               options="{'no_open': True}"/>
                        <field name="csv_file" filename="csv_filename"
                               widget="binary"/>
                        <field name="csv_filename" invisible="1"/>
                        <field name="has_header"/>
                    </group>

                    <div class="alert alert-info mt-3" role="alert">
                        <strong>CSV format</strong>
                        <ul class="mb-2">
                            <li>Column 1: <code>rubric_name</code>
                                — used to match existing rubrics
                                (case-insensitive)</li>
                            <li>Column 2: <code>rubric_description</code>
                                — info-only, ignored on import</li>
                            <li>Column 3: <code>rating</code> — numeric</li>
                            <li>Column 4: <code>justification</code> — text</li>
                        </ul>
                        <p class="mb-1"><strong>Tip:</strong> click
                            <em>Export to CSV</em> first on this seller's form
                            to get a file with the rubric names pre-filled.
                            Edit only columns 3 + 4 in Excel.</p>
                        <p class="mb-0 small text-muted">
                            Rows whose <code>rubric_name</code> doesn't match
                            an existing rubric on this task are reported and
                            skipped — this wizard updates scores only, it
                            doesn't create new rubrics.
                        </p>
                    </div>
                </sheet>
                <footer>
                    <button string="Import" type="object" name="action_import"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="fenrir_rubric_score_import_wizard_action" model="ir.actions.act_window">
        <field name="name">Import Rubric Scores from CSV</field>
        <field name="res_model">fenrir.rubric.score.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="fenrir_rubric_score_import_wizard_view_form"/>
        <field name="target">new</field>
    </record>

</odoo>
