<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fenrir_category_view_list" model="ir.ui.view">
        <field name="name">fenrir.category.list</field>
        <field name="model">fenrir.category</field>
        <field name="arch" type="xml">
            <list string="Categories" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="fenrir_category_view_form" model="ir.ui.view">
        <field name="name">fenrir.category.form</field>
        <field name="model">fenrir.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Category name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fenrir_category_view_search" model="ir.ui.view">
        <field name="name">fenrir.category.search</field>
        <field name="model">fenrir.category</field>
        <field name="arch" type="xml">
            <search string="Categories">
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="filter_archived"
                        domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="fenrir_category_action" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">fenrir.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new category
            </p>
            <p>
                Categories classify Fenrir tasks (e.g. Game Development, Web,
                AI / ML). Used by the Tasks list and search filters.
            </p>
        </field>
    </record>

</odoo>
