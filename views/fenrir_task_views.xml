<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fenrir_task_view_list" model="ir.ui.view">
        <field name="name">fenrir.task.list</field>
        <field name="model">fenrir.task</field>
        <field name="arch" type="xml">
            <list string="Tasks">
                <field name="code" decoration-bf="1"/>
                <field name="category_id"/>
                <field name="lead_user_id" options="{'no_open': True}"/>
                <field name="title"/>
                <field name="reviewer_id" widget="many2one_avatar_user"/>
                <field name="buyer_id" widget="many2one_avatar_user"/>
                <!-- <field name="pricing" sum="Total"/> -->
                <field name="price_tier" optional="hide"/>
                <field name="delivery_time"/>
                <field name="seller_offer_count" string="Sellers"/>
                <field name="accepted_offer_count" string="Accepted" optional="hide"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'approved' or status == 'completed'"
                       decoration-warning="status == 'pending_review'"
                       decoration-danger="status == 'cancelled' or status == 'rejected'"/>
                <field name="submitted_at"/>
            </list>
        </field>
    </record>

    <record id="fenrir_task_view_form" model="ir.ui.view">
        <field name="name">fenrir.task.form</field>
        <field name="model">fenrir.task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <header>
                    <button name="action_submit_task" type="object"
                            string="Submit Task" class="btn-primary"
                            invisible="status not in (False, 'draft')"/>
                    <button name="action_submit_task" type="object"
                            string="Re-Submit" class="btn-warning"
                            invisible="status not in ('pending_review', 'approved', 'completed', 'rejected')"/>
                    <button name="action_approve_task" type="object"
                            string="Approve" class="btn-primary"
                            groups="fenrir.group_fenrir_manager"
                            invisible="not id or status != 'pending_review'"/>
                    <button name="action_reject_task" type="object"
                            string="Reject" class="btn-danger"
                            groups="fenrir.group_fenrir_manager"
                            invisible="not id or status != 'pending_review'"/>
                    <button name="action_complete_task" type="object"
                            string="Complete" class="btn-primary"
                            groups="fenrir.group_fenrir_manager"
                            invisible="not id or status != 'approved'"/>
                    <button name="action_reapprove_task" type="object"
                            string="Re-approve" class="btn-warning"
                            groups="fenrir.group_fenrir_manager"
                            invisible="not id or status not in ('approved', 'completed')"
                            confirm="Re-approve will regenerate and overwrite this task's files in Google Drive. Continue?"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,pending_review,approved,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_seller_offers" type="object"
                                class="oe_stat_button" icon="fa-handshake-o">
                            <field name="seller_offer_count" widget="statinfo"
                                   string="Sellers"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="code" string="Task Code"/>
                        <h1 class="mb-0">
                            <field name="code" placeholder="e.g. GDV-002"/>
                        </h1>
                        <h2 class="text-muted mt-1">
                            <field name="title" placeholder="Project title..."/>
                        </h2>
                    </div>

                    <group>
                        <group string="Classification" name="group_classification">
                            <field name="category_id" options="{'no_create_edit': True}"/>
                            <field name="subcategory" placeholder="e.g. Logo Design"/>
                            <field name="lead_user_id" options="{'no_open': True}"/>
                            <field name="reviewer_id" widget="many2one_avatar_user"/>
                            <field name="difficulty_estimate"/>
                            <field name="estimated_completion_time_hours"/>
                            <field name="tags" placeholder="logo, vintage, emblem"/>
                        </group>
                        <group string="Buyer &amp; Pricing" name="group_pricing">
                            <field name="buyer_id" widget="many2one_avatar_user"/>
                            <!-- <field name="pricing" widget="float"/> -->
                            <field name="price_tier"/>
                            <field name="delivery_time"/>
                            <field name="order_accepted_date"/>
                        </group>
                    </group>

                    <group invisible="not drive_folder_id" string="Google Drive"
                           name="group_drive">
                        <field name="drive_folder_url" widget="url"/>
                        <field name="drive_last_uploaded_at"/>
                    </group>

                    <separator string="Recreation Notes" name="sep_recreation"/>
                    <field name="recreation_notes" nolabel="1"
                           placeholder="How the original gig concept was adapted, what was fictionalized, confirmation that no proprietary assets were used..."/>

                    <separator string="Overview" name="sep_overview"/>
                    <field name="overview" nolabel="1"
                           placeholder="Brief project overview..."/>

                    <separator string="Scope of Work" name="sep_scope"/>
                    <field name="scope_of_work" nolabel="1"
                           placeholder="What needs to be built / delivered..."/>

                    <separator string="Company Details" name="sep_company"/>
                    <field name="company_details" nolabel="1"
                           placeholder="Company name, location, contact..."/>

                    <separator string="Resources" name="sep_resources"/>
                    <!-- <group>
                        <label for="assets_url" string="Assets"/>
                        <div class="o_row">
                            <field name="assets_url" widget="url"
                                   placeholder="https://..." nolabel="1"/>
                            <field name="assets_file" filename="assets_filename"
                                   widget="binary" nolabel="1"/>
                            <field name="assets_filename" invisible="1"/>
                        </div>
                        <label for="rubrics_url" string="Rubrics"/>
                        <div class="o_row">
                            <field name="rubrics_url" widget="url"
                                   placeholder="https://..." nolabel="1"/>
                            <field name="rubrics_file" filename="rubrics_filename"
                                   widget="binary" nolabel="1"/>
                            <field name="rubrics_filename" invisible="1"/>
                        </div>
