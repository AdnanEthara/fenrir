                                   filename="instruction_md_filename"
                                   widget="binary" nolabel="1"/>
                            <field name="instruction_md_filename" invisible="1"/>
                        </div>
                    </group> -->
                    <group>
                        <label for="assets_file" string="Project Requirements Document (PRD)"/>
                        <div class="o_row">
                            <field name="assets_file" filename="assets_filename"
                                widget="binary" nolabel="1"/>
                            <field name="assets_filename" invisible="1"/>
                        </div>
                        <label for="instruction_md_file" string="Instruction.md"/>
                        <div class="o_row">
                            <field name="instruction_md_file"
                                filename="instruction_md_filename"
                                widget="binary" nolabel="1"/>
                            <field name="instruction_md_filename" invisible="1"/>
                        </div>
                    </group>
                    <field name="instruction_notes"
                           placeholder="Notes about instruction.md (used in license.json)..."/>

                    <separator string="Rubrics" name="sep_rubrics"/>
                    <div class="mb-2 d-flex gap-2 align-items-center">
                        <button name="%(fenrir.fenrir_rubric_import_wizard_action)d"
                                type="action"
                                string="Import from CSV"
                                class="btn-secondary"
                                context="{'default_task_id': id}"
                                icon="fa-upload"/>
                        <a href="/fenrir/static/src/sample_rubrics.csv"
                           download="sample_rubrics.csv"
                           class="btn btn-link btn-sm">
                            <i class="fa fa-download me-1"
                               title="Download" aria-label="Download"
                               role="img"/>
                            Download sample CSV
                        </a>
                        <span class="text-muted small">
                            (clicking Import on a new task saves it first)
                        </span>
                    </div>
                    <field name="rubric_ids" nolabel="1" mode="kanban,list">
                        <kanban class="o_kanban_dashboard">
                            <field name="name"/>
                            <field name="description"/>
                            <field name="sequence"/>
                            <templates>
                                <t t-name="card">
                                    <div class="oe_kanban_card oe_kanban_global_click p-2">
                                        <div class="mb-1">
                                            <strong class="text-truncate">
                                                <field name="name" placeholder="Rubric name"/>
                                            </strong>
                                        </div>
                                        <div class="text-muted small" t-if="record.description.raw_value">
                                            <field name="description"/>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                        <list editable="bottom" string="Rubrics">
                            <field name="sequence" widget="handle"/>
                            <field name="name" placeholder="Rubric name..."/>
                            <field name="description" placeholder="What this measures..."/>
                        </list>
                        <form string="Rubric">
                            <sheet>
                                <div class="oe_title">
                                    <label for="name"/>
                                    <h1><field name="name" placeholder="Rubric name..."/></h1>
                                </div>
                                <group>
                                    <field name="sequence"/>
                                </group>
                                <separator string="Description"/>
                                <field name="description" nolabel="1"
                                       placeholder="What this rubric measures..."/>
                            </sheet>
                        </form>
                    </field>

                    <separator string="Attachments" name="sep_attachments"/>
                    <widget name="fenrir_attachment_uploader"/>
                    <field name="attachment_ids" nolabel="1" mode="kanban,list"
                           domain="[('folder', '!=', 'data')]">
                        <kanban class="o_kanban_dashboard">
                            <field name="file_name"/>
                            <field name="attachment"/>
                            <field name="s3_key"/>
                            <field name="description"/>
                            <field name="sequence"/>
                            <templates>
                                <t t-name="card">
                                    <div class="oe_kanban_card oe_kanban_global_click p-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fa fa-paperclip fa-lg text-primary"
                                               title="Attachment" aria-label="Attachment" role="img"/>
                                            <strong class="text-truncate flex-grow-1">
                                                <field name="file_name" placeholder="File name"/>
                                            </strong>
                                        </div>
                                        <div class="text-muted small mt-1 text-truncate" t-if="record.description.raw_value">
                                            <field name="description"/>
                                        </div>
                                        <div class="mt-2" t-if="!record.s3_key.raw_value">
                                            <field name="attachment" filename="file_name" widget="binary"/>
                                        </div>
                                        <div class="mt-2 small text-success" t-if="record.s3_key.raw_value">
                                            <i class="fa fa-cloud" aria-hidden="true"/> Stored in S3
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                        <list editable="bottom" string="Attachments"
                              decoration-info="is_generated"
                              decoration-success="s3_key">
                            <field name="sequence" widget="handle"/>
                            <field name="file_name" placeholder="logo.png"/>
                            <field name="folder"/>
                            <field name="is_generated" widget="boolean_toggle"
                                   readonly="1" optional="show"/>
                            <field name="license"/>
                            <field name="source_url" optional="show"
                                   placeholder="https://..."/>
                            <field name="attachment" filename="file_name" string="File"
                                   invisible="s3_key"/>
                            <field name="s3_key" optional="show" readonly="1"/>
                            <field name="s3_uploaded_at" optional="hide" readonly="1"/>
                            <field name="file_size" optional="hide" readonly="1"/>
                            <button name="action_open_s3_download" type="object"
                                    icon="fa-cloud-download" title="Download from S3"
                                    invisible="not s3_key"/>
                            <field name="description" optional="hide"
                                   placeholder="Optional caption..."/>
                            <field name="notes"
                                   placeholder="Notes for license.json..."/>
                        </list>
                        <form string="Attachment">
                            <sheet>
                                <div class="oe_title">
                                    <label for="file_name"/>
                                    <h1><field name="file_name" placeholder="logo.png"/></h1>
                                </div>
                                <group>
                                    <group string="Export">
                                        <field name="folder"/>
                                        <field name="license"/>
                                        <field name="source_url"
                                               placeholder="https://..."/>
                                    </group>
                                    <group string="Display">
                                        <field name="description"
                                               placeholder="Optional caption..."/>
                                        <field name="sequence"/>
                                    </group>
                                </group>
                                <separator string="File"/>
                                <field name="attachment" filename="file_name"
                                       nolabel="1" widget="binary"
                                       invisible="s3_key"/>
                                <div invisible="not s3_key" class="alert alert-info mb-2" role="status">
                                    Stored in S3 —
                                    <field name="s3_key" readonly="1" class="oe_inline"/>
                                    (<field name="file_size" readonly="1" class="oe_inline"/> bytes,
                                    uploaded <field name="s3_uploaded_at" readonly="1" class="oe_inline"/>).
                                    <button name="action_open_s3_download" type="object"
                                            string="Download" class="btn-link"
                                            icon="fa-cloud-download"/>
                                </div>
                                <separator string="Notes"/>
                                <field name="notes" nolabel="1"
                                       placeholder="Notes about this asset (used in license.json)..."/>
                            </sheet>
                        </form>
                    </field>

                    <!-- <separator string="Data" name="sep_data"/>
                    <widget name="fenrir_attachment_uploader" default_folder="data"/>
