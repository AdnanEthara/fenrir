<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_fenrir" model="ir.module.category">
            <field name="name">Fenrir</field>
            <field name="description">Fenrir freelancer task tracker.</field>
            <field name="sequence">20</field>
        </record>

        <record id="res_groups_privilege_fenrir" model="res.groups.privilege">
            <field name="name">Fenrir</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="module_category_fenrir"/>
        </record>

        <record id="group_fenrir_tasker" model="res.groups">
            <field name="name">Tasker</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="res_groups_privilege_fenrir"/>
            <field name="comment">Works on assigned tasks; sees only their own records.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_fenrir_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="res_groups_privilege_fenrir"/>
            <field name="comment">Sees and manages every task across the organization.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_fenrir_tasker'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin')), (4, ref('base.user_root'))]"/>
        </record>

    </data>

    <data noupdate="1">

        <record id="rule_fenrir_task_user_own" model="ir.rule">
            <field name="name">Fenrir Task: user sees own</field>
            <field name="model_id" ref="model_fenrir_task"/>
            <field name="domain_force">[('lead_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_fenrir_task_manager_all" model="ir.rule">
            <field name="name">Fenrir Task: manager sees all</field>
            <field name="model_id" ref="model_fenrir_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fenrir_manager'))]"/>
        </record>

        <record id="rule_fenrir_seller_offer_user_own" model="ir.rule">
            <field name="name">Fenrir Seller Offer: user sees own task's</field>
            <field name="model_id" ref="model_fenrir_seller_offer"/>
            <field name="domain_force">[('task_id.lead_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_fenrir_seller_offer_manager_all" model="ir.rule">
            <field name="name">Fenrir Seller Offer: manager sees all</field>
            <field name="model_id" ref="model_fenrir_seller_offer"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fenrir_manager'))]"/>
        </record>

        <record id="rule_fenrir_rubric_user_own" model="ir.rule">
            <field name="name">Fenrir Rubric: user sees own task's</field>
            <field name="model_id" ref="model_fenrir_rubric"/>
            <field name="domain_force">[('task_id.lead_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_fenrir_rubric_manager_all" model="ir.rule">
            <field name="name">Fenrir Rubric: manager sees all</field>
            <field name="model_id" ref="model_fenrir_rubric"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fenrir_manager'))]"/>
        </record>

        <record id="rule_fenrir_rubric_score_user_own" model="ir.rule">
            <field name="name">Fenrir Rubric Score: user sees own task's</field>
            <field name="model_id" ref="model_fenrir_rubric_score"/>
            <field name="domain_force">[('task_id.lead_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_fenrir_rubric_score_manager_all" model="ir.rule">
            <field name="name">Fenrir Rubric Score: manager sees all</field>
            <field name="model_id" ref="model_fenrir_rubric_score"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fenrir_manager'))]"/>
        </record>

        <record id="rule_fenrir_task_attachment_user_own" model="ir.rule">
            <field name="name">Fenrir Task Attachment: user sees own task's</field>
            <field name="model_id" ref="model_fenrir_task_attachment"/>
            <field name="domain_force">[('task_id.lead_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_fenrir_task_attachment_manager_all" model="ir.rule">
            <field name="name">Fenrir Task Attachment: manager sees all</field>
            <field name="model_id" ref="model_fenrir_task_attachment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fenrir_manager'))]"/>
        </record>

        <record id="rule_fenrir_input_asset_license_user_own" model="ir.rule">
            <field name="name">Fenrir Input Asset License: user sees own task's</field>
            <field name="model_id" ref="model_fenrir_input_asset_license"/>
            <field name="domain_force">[('task_id.lead_user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_fenrir_input_asset_license_manager_all" model="ir.rule">
            <field name="name">Fenrir Input Asset License: manager sees all</field>
            <field name="model_id" ref="model_fenrir_input_asset_license"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fenrir_manager'))]"/>
        </record>

    </data>
</odoo>
